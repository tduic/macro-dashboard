# Get a free FRED API key at https://fred.stlouisfed.org/docs/api/api_key.html
# (free account -> "My Account" -> "API Keys" -> request a key)
# The app runs WITHOUT this key, but Rates / Economic Data / Calendar panels
# (which depend on FRED) will be disabled and a banner will tell you to add it.
FRED_API_KEY=

# Optional: override the host/port the backend binds to
# HOST=127.0.0.1
# PORT=8000
